# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Options: development, production
# - development: Shows detailed error messages and stack traces
# - production: Shows generic error messages (recommended for live sites)
APP_ENV=production

# ============================================
# DATABASE CREDENTIALS
# ============================================
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ============================================
# ADMIN CREDENTIALS
# ============================================
ADMIN_USERNAME=admin
# Generate hash: php -r "echo password_hash('your_password', PASSWORD_BCRYPT);"
ADMIN_PASS_HASH=$2y$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# LEMONSQUEEZY PAYMENT GATEWAY
# ============================================
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# GUMROAD PAYMENT GATEWAY
# ============================================
GUMROAD_WEBHOOK_SECRET=your_gumroad_webhook_secret

# ============================================
# API KEYS
# ============================================
CRON_AUTH_KEY=your_random_cron_auth_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# BACKUP ENCRYPTION KEY
# ============================================
# Generate a secure 64-character hex key with:
# php -r "echo bin2hex(random_bytes(32));"
# IMPORTANT: Keep this secret and never commit to repository!
BACKUP_ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App Name
APP_NAME=Your App Name
APP_URL=https://yourdomain.com

# ============================================
# ALERT NOTIFICATIONS
# ============================================
# Admin email for critical alerts
ADMIN_EMAIL=admin@yourdomain.com

# Webhook URL for alerts (Slack, Discord, etc.)
# Leave empty to disable webhook notifications
ALERT_WEBHOOK_URL=
# Webhook type: slack, discord, or generic
ALERT_WEBHOOK_TYPE=slack

# ============================================
# SMTP EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_ENCRYPTION=tls
